generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  status      String   @default("active") // active, paused, completed, archived
  techStack   String   @default("[]") // JSON array: ["typescript", "react", "next.js"]
  repoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
  messages    Message[]
  files       ProjectFile[]
  buildLogs   BuildLog[]
}

model Agent {
  id            String   @id @default(cuid())
  name          String
  role          String   // architect, developer, reviewer, tester, devops, pm
  status        String   @default("idle") // idle, thinking, coding, reviewing, testing, deploying, sleeping
  avatar        String   @default("") // emoji or color
  specialty     String   @default("")
  currentTaskId String?
  tokensUsed    Int      @default(0)
  tasksCompleted Int     @default(0)
  successRate   Float    @default(0.95)
  lastActive    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      Message[]
  activities    AgentActivity[]
  assignedTasks Task[]
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String   @default("")
  status      String   @default("backlog") // backlog, todo, in_progress, in_review, done, blocked
  priority    String   @default("medium") // critical, high, medium, low
  type        String   @default("feature") // feature, bugfix, refactor, test, docs, infra
  assigneeId  String?
  parentTaskId String?
  subtasks    String   @default("[]") // JSON array of subtask descriptions
  output      String   @default("") // task result/output
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    Agent?   @relation(fields: [assigneeId], references: [id])
}

model Message {
  id          String   @id @default(cuid())
  projectId   String
  agentId     String?
  content     String
  type        String   @default("chat") // chat, system, action, code_change, review_comment, test_result, deploy_log
  metadata    String   @default("{}") // JSON
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent       Agent?   @relation(fields: [agentId], references: [id])
}

model ProjectFile {
  id          String   @id @default(cuid())
  projectId   String
  path        String
  content     String   @default("")
  language    String   @default("typescript")
  isDirectory Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
}

model BuildLog {
  id          String   @id @default(cuid())
  projectId   String
  output      String
  status      String   @default("running") // running, success, failed, warning
  type        String   @default("build") // build, test, lint, deploy
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AgentActivity {
  id          String   @id @default(cuid())
  agentId     String
  action      String   // task_started, code_written, review_completed, test_run, deploy_triggered, message_sent
  description String
  metadata    String   @default("{}") // JSON
  createdAt   DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}
