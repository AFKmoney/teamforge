generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  status      String   @default("active") // active, paused, completed, archived
  techStack   String   @default("[]") // JSON array: ["typescript", "react", "next.js"]
  repoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
  messages    Message[]
  chatSessions ChatSession[]
  files       ProjectFile[]
  buildLogs   BuildLog[]
  benchmarkSnapshots BenchmarkSnapshot[]
}

model Agent {
  id            String   @id @default(cuid())
  name          String
  role          String   // architect, developer, reviewer, tester, devops, pm
  status        String   @default("idle") // idle, thinking, coding, reviewing, testing, deploying, sleeping
  avatar        String   @default("") // emoji or color
  specialty     String   @default("")
  currentTaskId String?
  tokensUsed    Int      @default(0)
  tasksCompleted Int     @default(0)
  successRate   Float    @default(0.95)
  lastActive    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      Message[]
  activities    AgentActivity[]
  metrics       AgentMetric[]
  assignedTasks Task[]
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String   @default("")
  status      String   @default("backlog") // backlog, todo, in_progress, in_review, done, blocked
  priority    String   @default("medium") // critical, high, medium, low
  type        String   @default("feature") // feature, bugfix, refactor, test, docs, infra
  assigneeId  String?
  parentTaskId String?
  subtasks    String   @default("[]") // JSON array of subtask descriptions
  output      String   @default("") // task result/output
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    Agent?   @relation(fields: [assigneeId], references: [id])
}

model ChatSession {
  id          String   @id @default(cuid())
  projectId   String
  title       String   @default("New Chat")
  summary     String   @default("") // Auto-generated summary of the conversation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages    Message[]
}

model Message {
  id            String   @id @default(cuid())
  projectId     String
  chatSessionId String?
  agentId       String?
  content       String
  type          String   @default("chat") // chat, system, action, code_change, review_comment, test_result, deploy_log
  metadata      String   @default("{}") // JSON
  createdAt     DateTime @default(now())

  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chatSession   ChatSession? @relation(fields: [chatSessionId], references: [id], onDelete: SetNull)
  agent         Agent?     @relation(fields: [agentId], references: [id])
}

model ProjectFile {
  id          String   @id @default(cuid())
  projectId   String
  path        String
  content     String   @default("")
  language    String   @default("typescript")
  isDirectory Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
}

model BuildLog {
  id          String   @id @default(cuid())
  projectId   String
  output      String
  status      String   @default("running") // running, success, failed, warning
  type        String   @default("build") // build, test, lint, deploy
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AgentActivity {
  id          String   @id @default(cuid())
  agentId     String
  action      String   // task_started, task_assigned, task_completed, code_written, review_completed, test_run, deploy_triggered, message_sent, status_change, file_created, file_updated, code_change
  description String
  metadata    String   @default("{}") // JSON
  createdAt   DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AgentMetric {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  timestamp   DateTime @default(now())
  
  // Task metrics
  tasksAssigned    Int      @default(0)
  tasksCompleted   Int      @default(0)
  tasksFailed      Int      @default(0)
  
  // Time metrics (in seconds)
  avgResolutionTime    Float @default(0)
  medianResolutionTime Float @default(0)
  
  // Quality metrics
  reviewPassRate       Float @default(0)  // % of tasks that pass review on first attempt
  postReviewCorrections Int  @default(0)  // number of corrections needed after review
  
  // Autonomy metrics
  autonomousActions    Int   @default(0)  // actions taken without human intervention
  humanInterventions   Int   @default(0)  // times human had to step in
  
  // Token usage
  tokensUsed           Int   @default(0)
  
  // Session info
  sessionId            String?  // link to a work session for time-series analysis
}

model BenchmarkSnapshot {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timestamp   DateTime @default(now())
  
  // Aggregate system metrics
  totalTasksCreated      Int     @default(0)
  totalTasksCompleted    Int     @default(0)
  totalTasksFailed       Int     @default(0)
  
  // Time metrics
  meanResolutionTime     Float   @default(0)  // avg time from task creation to completion
  p50ResolutionTime      Float   @default(0)  // median
  p95ResolutionTime      Float   @default(0)  // 95th percentile
  p99ResolutionTime      Float   @default(0)  // 99th percentile
  
  // Quality
  firstPassRate          Float   @default(0)  // % tasks passing review on first try
  avgPostReviewFixes     Float   @default(0)  // avg corrections per task
  
  // Autonomy
  autonomyRate           Float   @default(0)  // % of actions without human intervention
  avgHumanInterventions  Float   @default(0)  // avg interventions per task
  
  // Throughput
  tasksPerHour           Float   @default(0)  // tasks completed per hour
  linesPerHour           Float   @default(0)  // lines of code changed per hour
  
  // Stability
  uptimeHours            Float   @default(0)  // hours since last agent crash/reset
  errorRate              Float   @default(0)  // % of agent actions that resulted in errors
  
  // Token efficiency
  totalTokensUsed        Int     @default(0)
  tokensPerTask          Float   @default(0)  // avg tokens per completed task
  tokensPerLine          Float   @default(0)  // avg tokens per line of code changed
}
